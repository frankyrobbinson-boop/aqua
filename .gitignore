.env
venv/
__pycache__/

# Generated video output — large binaries, regenerated on demand
# Anchored to repo root so frontend/src/app/projects/ isn't matched.
/projects/

# Rendered Remotion MP4s (motion-graphics module output)
/backend/output/remotion/

# Local ML model blobs (downloaded on demand by probes, e.g. u2netp.onnx); the
# tracked backend/models/research.py stays committed.
/backend/models/*.onnx

# Drop-in background-music beds (maintainer-supplied audio); the tracked
# backend/music/README.md stays committed.
/backend/music/*.mp3
/backend/music/*.wav
/backend/music/*.m4a

# macOS Finder metadata
.DS_Store

# Local Claude Code settings (per-machine permissions); commit .claude/agents/
.claude/settings.local.json

# Local reference material + design-source archives (large binaries, not build inputs)
/assets/
/references/
