# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# footage-transition rating clips: local source clips staged into public/ for
# the headless renderer (it serves public/ over http, can't read file://).
# Transient render inputs — never committed.
/public/xtrans-src/

# blur-dissolve pipeline: scene clips staged into public/ for the headless
# FootageTransition window render (assembly_service). Transient — never committed.
/public/blurdissolve-src/

# OST overlay design renders: footage stills staged into public/ for the headless
# overlay renders (scripts/render-ost-overlays.mjs). The renderer serves public/
# over http (can't read file://). Transient render inputs — never committed.
/public/ost-src/
