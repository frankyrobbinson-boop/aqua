# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# OpenAI — used by the research stage (GPT-5). Get a key at
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — used for script generation (Claude Opus) and visual rerank
# (Claude Haiku). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ElevenLabs — used for text-to-speech voiceover. Get a key at
# https://elevenlabs.io/app/settings/api-keys and pick any voice's ID.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Optional ElevenLabs overrides:
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_CONCURRENCY=3   # drop to 2 on the free tier to avoid 429s

# Pexels — used for stock footage. Free key at https://www.pexels.com/api/
PEXELS_API_KEY=

# Google Gemini — used by the Nano Banana visual provider (gemini-2.5-flash-image,
# ~$0.039/image). Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional Nano Banana override:
# GEMINI_CONCURRENCY=8       # max parallel image generations per provider instance
