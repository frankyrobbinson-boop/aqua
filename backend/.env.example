# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# OpenAI — used by the research stage (GPT-5). Get a key at
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — used for script generation (Claude Opus). Get a key at
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ElevenLabs — used for text-to-speech voiceover. Get a key at
# https://elevenlabs.io/app/settings/api-keys and pick any voice's ID.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Optional ElevenLabs overrides:
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_CONCURRENCY=3   # drop to 2 on the free tier to avoid 429s

# Pexels — used for stock footage. Free key at https://www.pexels.com/api/
PEXELS_API_KEY=

# Google Gemini — used by the Nano Banana visual provider (gemini-2.5-flash-image,
# ~$0.039/image). Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional Nano Banana override:
# GEMINI_CONCURRENCY=8       # max parallel image generations per provider instance

# Qwen3 voice providers (registered as stubs in Phase 1; not yet wired):
# DASHSCOPE_API_KEY=         # for Qwen3 hosted provider (Phase 2a)
# WAVESPEED_API_KEY=         # alternative Qwen3 hosted backend

# --- Render knobs (optional; all free/local, read at render time) ---
# RENDER_KB_CAMERA=1         # default ON: one continuous Ken Burns ping-pong zoom
#                            #   shared across each run of stills (motion flows
#                            #   through the cuts) + auto-targeting on each still's
#                            #   subject (aim mode set by RENDER_KB_DRIFT). "=0"
#                            #   restores the legacy per-scene center zoom.
# RENDER_KB_DRIFT=0          # default OFF: PIVOT — the KB zoom aims at a FIXED
#                            #   anchor, tightening on the subject where it sits
#                            #   (targeted zoom, no lateral slide). "=1" DRIFTS the
#                            #   crop from centre toward the subject as it zooms in
#                            #   (drift-to-center).
# RENDER_OST_DRAWTEXT=0      # default OFF: no burned-in drawtext OST (header /
#                            #   callout / counter overlays). "=1" re-enables it for
#                            #   debugging. Cards + subtitles are unaffected.
# RENDER_KB_INTERP=lanczos4  # subpixel-warp interpolation: "cubic" (faster) or
#                            #   "lanczos4" (default, sharpest).
